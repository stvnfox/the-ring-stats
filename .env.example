# Google Sheet (from the spreadsheet URL: .../d/<ID>/edit)
GOOGLE_SPREADSHEET_ID=

# Paste the full service account JSON on one line (GCP → IAM → service account → Keys → JSON)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Set to true to show sample leaderboards when the sheet is missing, errors, or has no parsed rows
# DASHBOARD_USE_DUMMY_DATA=true

# Client-only (must be prefixed VITE_). Restart dev server after changes; production needs a rebuild.
# Dashboard: interval in ms. Default 30000. 0 = no polling and no refetch on tab focus / reconnect.
# VITE_DASHBOARD_REFETCH_MS=30000
# When false (default), polling pauses if Tournaments tab says no event—set true to keep polling anyway.
# VITE_DASHBOARD_POLL_WHEN_IDLE=false

# Optional: override tab names if yours differ (defaults match common setup)
# SHEET_TAB_TOURNAMENTS=Tournaments
# SHEET_TAB_TOP_FRAGGER=PlayerTotals
# SHEET_TAB_TEAM_SCORES=TeamTotals
# SHEET_TAB_MAP_SCORES=MapScores
